{
  "name": "cadmus-shell-v3",
  "version": "1.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "build-cor": "ng build @myrmidon/cadmus-core",
    "build-api": "ng build @myrmidon/cadmus-api",
    "build-ui": "ng build @myrmidon/cadmus-state && ng build @myrmidon/cadmus-ui",
    "build-ths": "ng build @myrmidon/cadmus-profile-core && ng build @myrmidon/cadmus-thesaurus-ui && ng build @myrmidon/cadmus-thesaurus-editor && ng build @myrmidon/cadmus-thesaurus-list",
    "build-gen": "ng build @myrmidon/cadmus-part-general-ui && ng build @myrmidon/cadmus-part-general-pg",
    "build-imp": "ng build @myrmidon/cadmus-profile-import",
    "build-prd": "ng build @myrmidon/cadmus-profile-editor",
    "build-phi": "ng build @myrmidon/cadmus-part-philology-ui && ng build @myrmidon/cadmus-part-philology-pg",
    "build-itm": "ng build @myrmidon/cadmus-item-list && ng build @myrmidon/cadmus-item-editor && ng build @myrmidon/cadmus-item-search && ng build @myrmidon/cadmus-layer-demo",
    "build-grp": "ng build @myrmidon/cadmus-graph-ui && ng build @myrmidon/cadmus-graph-ui-ex && ng build @myrmidon/cadmus-graph-pg && ng build @myrmidon/cadmus-graph-pg-ex",
    "build-pre": "ng build @myrmidon/cadmus-preview-ui && ng build @myrmidon/cadmus-preview-pg",
    "build-flg": "ng build @myrmidon/cadmus-flags-ui && ng build @myrmidon/cadmus-flags-pg",
    "build-sta": "ng build @myrmidon/cadmus-statistics",
    "build-tax": "ng build @myrmidon/cadmus-part-taxo-ui && ng build @myrmidon/cadmus-part-taxo-pg",
    "build-lib": "pnpm run build-cor && pnpm run build-api && pnpm run build-ui && pnpm run build-itm && pnpm run build-ths && pnpm run build-gen && pnpm run build-phi && pnpm run build-grp && pnpm run build-pre && pnpm run build-flg && pnpm run build-sta && pnpm run build-tax && pnpm run build-imp && pnpm run build-prd",
    "build-all": "pnpm run build-lib && ng build",
    "test-all": "ng test --watch=false --browsers=ChromeHeadlessNoSandbox"
  },
  "overrides": {
    "d3-selection": "3.0.0"
  },
  "private": true,
  "packageManager": "pnpm@11.6.0",
  "dependencies": {
    "3d-force-graph": "^1.80.0",
    "@angular/animations": "^22.0.1",
    "@angular/cdk": "^22.0.1",
    "@angular/common": "^22.0.1",
    "@angular/compiler": "^22.0.1",
    "@angular/core": "^22.0.1",
    "@angular/forms": "^22.0.1",
    "@angular/material": "^22.0.1",
    "@angular/platform-browser": "^22.0.1",
    "@angular/platform-browser-dynamic": "^22.0.1",
    "@angular/router": "^22.0.1",
    "@auth0/angular-jwt": "^5.2.0",
    "@jean-merelis/ngx-monaco-editor": "^21.0.0",
    "@myrmidon/auth-jwt-admin": "9.0.0",
    "@myrmidon/auth-jwt-login": "9.0.0",
    "@myrmidon/cadmus-api": "link:./dist/myrmidon/cadmus-api",
    "@myrmidon/cadmus-mat-physical-size": "^10.0.0",
    "@myrmidon/cadmus-mat-physical-state": "^10.0.0",
    "@myrmidon/cadmus-refs-asserted-chronotope": "12.0.0",
    "@myrmidon/cadmus-refs-asserted-ids": "^11.0.0",
    "@myrmidon/cadmus-refs-assertion": "11.0.0",
    "@myrmidon/cadmus-refs-biblissima-lookup": "^11.0.0",
    "@myrmidon/cadmus-refs-citation": "^2.0.0",
    "@myrmidon/cadmus-refs-decorated-counts": "^10.0.0",
    "@myrmidon/cadmus-refs-doc-references": "^11.0.0",
    "@myrmidon/cadmus-refs-geonames-lookup": "^11.0.0",
    "@myrmidon/cadmus-refs-historical-date": "10.0.0",
    "@myrmidon/cadmus-refs-lookup": "^11.0.0",
    "@myrmidon/cadmus-refs-proper-name": "11.0.0",
    "@myrmidon/cadmus-refs-viaf-lookup": "^11.0.0",
    "@myrmidon/cadmus-text-block-view": "^10.0.0",
    "@myrmidon/cadmus-text-ed": "^11.0.0",
    "@myrmidon/cadmus-text-ed-md": "^12.0.0",
    "@myrmidon/cadmus-text-ed-txt": "^11.0.0",
    "@myrmidon/cadmus-thesaurus-store": "^1.0.0",
    "@myrmidon/cadmus-ui-flag-set": "^10.0.0",
    "@myrmidon/cadmus-ui-note-set": "^12.0.0",
    "@myrmidon/ngx-mat-tools": "^2.0.0",
    "@myrmidon/ngx-tools": "^3.0.0",
    "@myrmidon/paged-data-browsers": "^6.0.0",
    "@myrmidon/taxo-store-api": "^1.0.1",
    "@myrmidon/taxo-store-editor": "^1.0.0",
    "@myrmidon/taxo-store-picker": "^1.0.0",
    "d3-force": "^3.0.0",
    "echarts": "^6.1.0",
    "force-graph": "^1.51.4",
    "marked": "^18.0.5",
    "monaco-editor": "^0.47.0",
    "ngx-echarts": "^22.0.0",
    "rxjs": "~7.8.0",
    "three": "^0.184.0",
    "ts-md5": "^2.0.1",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^22.0.1",
    "@angular/cli": "^22.0.1",
    "@angular/compiler-cli": "^22.0.1",
    "@angular/localize": "^22.0.1",
    "@types/d3-force": "^3.0.10",
    "@types/jasmine": "~6.0.0",
    "@types/three": "^0.184.1",
    "istanbul-lib-instrument": "^6.0.3",
    "jasmine-core": "~6.3.0",
    "jsdom": "^29.1.1",
    "karma": "~6.4.4",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.1",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.2.0",
    "ng-packagr": "^22.0.0",
    "typescript": "~6.0.3",
    "vitest": "^4.1.8"
  },
  "optionalDependencies": {
    "@rollup/rollup-win32-arm64-msvc": "^4.61.1"
  },
  "pnpm": {
    "overrides": {
      "rollup": "npm:@rollup/wasm-node"
    }
  }
}
